<UserControl x:Class="Jarvis.Setup.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Memory"
                   FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.75"
                   Text="Optional personal context Jarvis 'knows' about you across sessions.
This becomes memory.md in the install folder.
Stays on your machine — never sent anywhere except to the LLM along with your messages.
You can leave it blank for now and edit it in Settings later."/>

        <CheckBox x:Name="MemoryEnabled" Grid.Row="2" Margin="0,0,0,8"
                  IsChecked="{Binding Memory.Enabled, Mode=TwoWay}"
                  Content="Give Jarvis a memory file"/>

        <TextBlock Grid.Row="3" Margin="0,0,0,4" Opacity="0.7" FontSize="11"
                   Text="Markdown is fine. Empty lines and headings (# Personal info) are encouraged."/>

        <TextBox Grid.Row="4" x:Name="MemoryBox"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="13"
                 IsEnabled="{Binding ElementName=MemoryEnabled, Path=IsChecked}"
                 Text="{Binding Memory.Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </Grid>
</UserControl>
