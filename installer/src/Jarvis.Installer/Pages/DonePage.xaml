<Page x:Class="Jarvis.Installer.Pages.DonePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Done">
    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="540" Margin="40">
            <TextBlock Text="🎉  Jarvis is ready"
                       FontSize="30" FontWeight="Light"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock x:Name="InstallPathText" TextWrapping="Wrap"
                       Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,24"
                       TextAlignment="Center"/>
            <CheckBox x:Name="LaunchCheck" Content="Launch Jarvis now"
                      IsChecked="True" HorizontalAlignment="Center"/>
            <TextBlock TextAlignment="Center" Margin="0,24,0,0" Opacity="0.7" FontSize="12"
                       Text="To change settings later, open 'Jarvis Settings' from the Start Menu."/>
        </StackPanel>
    </Grid>
</Page>
