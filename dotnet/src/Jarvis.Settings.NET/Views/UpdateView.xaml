<UserControl x:Class="Jarvis.Settings.NET.Views.UpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Updates"
                   FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,18" Opacity="0.75"
                   Text="Pull the latest Jarvis (.NET) build without re-running the installer."/>

        <!-- Version summary -->
        <Border Grid.Row="2" Background="#11000000" CornerRadius="4" Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Installed" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="InstalledVerLabel" Text="—" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Latest available" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="LatestVerLabel" Text="(checking...)" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="CheckBtn" Content="Check for updates" Height="32" Padding="14,0"
                    Click="CheckBtn_Click"/>
            <Button x:Name="UpdateBtn" Content="Download &amp; install update" Height="32"
                    Padding="14,0" IsEnabled="False" Margin="8,0,0,0"
                    Background="#1F6FEB" Foreground="White"
                    Click="UpdateBtn_Click"/>
            <ProgressBar x:Name="Progress" Height="6" Width="200" Margin="14,0,0,0"
                         Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center"
                         Visibility="Hidden"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="StatusLine" Margin="0,0,0,8" Opacity="0.8"/>

        <!-- Release notes -->
        <Border Grid.Row="5" BorderBrush="#DDDDDD" BorderThickness="1"
                Background="#FAFAFA" CornerRadius="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="NotesText" IsReadOnly="True" BorderThickness="0"
                         Background="Transparent" FontFamily="Consolas" FontSize="12"
                         TextWrapping="Wrap" Padding="10,8"
                         Text="Release notes will appear here after the auto-check completes."/>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="6" Margin="0,10,0,0" Opacity="0.55" FontSize="11"
                   TextWrapping="Wrap">
            Update fetches the latest tagged release from GitHub
            (Nitro70/ai-jarvis). The Jarvis-NET.exe and JarvisSettings-NET.exe
            binaries are replaced in place; your config.yaml and memory.md are
            NOT touched. The Settings app needs a restart after update.
        </TextBlock>
    </Grid>
</UserControl>
