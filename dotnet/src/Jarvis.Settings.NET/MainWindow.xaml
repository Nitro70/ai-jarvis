<Window x:Class="Jarvis.Settings.NET.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Jarvis.Settings.NET.Views"
        Title="Jarvis Settings (.NET)"
        Height="640" Width="820"
        MinHeight="540" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F1F2E" Padding="20,14">
            <StackPanel>
                <TextBlock Text="Jarvis Settings (.NET)" Foreground="White"
                           FontSize="20" FontWeight="SemiBold"/>
                <TextBlock x:Name="InstallDirLabel" Foreground="#BBB"
                           FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="12" Padding="0">
            <TabItem Header="AI backend">
                <views:LlmView x:Name="LlmTab"/>
            </TabItem>
            <TabItem Header="Voice">
                <views:VoiceView x:Name="VoiceTab"/>
            </TabItem>
            <TabItem Header="Memory">
                <views:MemoryView x:Name="MemoryTab"/>
            </TabItem>
            <TabItem Header="Tools">
                <views:ToolsView x:Name="ToolsTab"/>
            </TabItem>
            <TabItem Header="Updates">
                <views:UpdateView x:Name="UpdateTab"/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#EFEFEF" Padding="20,12"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Foreground="Gray"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Open install folder" Click="OpenFolder_Click"/>
                    <Button Content="Close" Click="Close_Click"/>
                    <Button Content="Save" IsDefault="True"
                            Background="#1F6FEB" Foreground="White"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
