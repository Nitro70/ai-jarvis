<Window x:Class="Jarvis.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Jarvis" Height="640" Width="780"
        MinHeight="400" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">
    <Window.Resources>
        <!-- Per-line styles. The chat log uses a Style.Triggers approach
             keyed off the LineKind property of the bound ChatLine. -->
        <Style x:Key="ChatLineStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status bar -->
        <Border Grid.Row="0" Background="#1F1F2E" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,8,0"
                             Fill="#888"/>
                    <TextBlock x:Name="StatusText" Foreground="White" FontSize="13"
                               VerticalAlignment="Center" Text="Ready."/>
                </StackPanel>
                <TextBlock x:Name="BackendLabel" Grid.Column="1" Foreground="#AAA" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Chat log -->
        <ScrollViewer x:Name="ChatScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="14,12">
            <ItemsControl x:Name="ChatItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ChatLineStyle}"
                                Background="{Binding BackgroundBrush}"
                                HorizontalAlignment="{Binding HorizontalAlignment}"
                                MaxWidth="640">
                            <StackPanel>
                                <TextBlock Text="{Binding Speaker}" FontSize="10"
                                           FontWeight="SemiBold" Opacity="0.7"
                                           Foreground="{Binding ForegroundBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                           FontSize="14" Foreground="{Binding ForegroundBrush}"
                                           FontStyle="{Binding FontStyle}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input row -->
        <Border Grid.Row="2" Background="#EFEFEF" Padding="12,10"
                BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="MicBtn" Grid.Column="0" Width="44" Height="36"
                              Margin="0,0,8,0" FontSize="18" Padding="0"
                              ToolTip="Toggle voice mode (wake word + STT)"
                              Click="MicBtn_Click"
                              Content="🎤"/>
                <TextBox x:Name="InputBox" Grid.Column="1" Height="36" FontSize="14"
                         KeyDown="InputBox_KeyDown"
                         AcceptsReturn="False"/>
                <Button x:Name="SendBtn" Grid.Column="2" Content="Send" Margin="8,0,0,0"
                        Height="36" Padding="20,0" IsDefault="True"
                        Background="#1F6FEB" Foreground="White" BorderThickness="0"
                        Click="SendBtn_Click"/>
            </Grid>
        </Border>

        <!-- Tray icon. Right-click menu = Show / Settings (TODO Phase 2) / Quit. -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Jarvis"
                        TrayLeftMouseUp="TrayIcon_Click">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show Jarvis" Click="ShowMenu_Click"/>
                    <Separator/>
                    <MenuItem Header="Quit" Click="QuitMenu_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
